rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Products collection — allow all reads and writes
    match /products/{documentId} {
      allow read, write: if true;
    }

    // Reviews collection:
    // - Anyone can READ reviews (homepage testimonials)
    // - Anyone can CREATE a review (customer review form)
    // - Anyone can UPDATE/DELETE (admin uses PIN auth, not Firebase Auth)
    match /reviews/{reviewId} {
      allow read, create: if true;
      allow update, delete: if true;
    }

    // Sold items and any other collections
    match /sold_items/{documentId} {
      allow read, write: if true;
    }

    // Block everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
